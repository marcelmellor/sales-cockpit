# HubSpot authentication
# The app uses a HubSpot Private App Token issued from the sipgate 2025
# HubSpot (Account ID 27058496). Only admins in that hub can create one —
# see AGENTS.md → "HubSpot authentication" for the exact procedure and
# which scopes the token needs.
# Format: pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HUBSPOT_PRIVATE_APP_TOKEN="pat-eu1-your-private-app-token"

# NextAuth v5 (Google sign-in for the cockpit's own users)
# AUTH_URL should be your app's public URL (e.g., https://yourdomain.com in production)
AUTH_URL="http://localhost:4000"
# Generate a secret with: openssl rand -base64 32
# NextAuth v5 uses AUTH_SECRET (NEXTAUTH_SECRET is legacy but also supported)
AUTH_SECRET="your-auth-secret-generate-with-openssl-rand-base64-32"

# Google OAuth for sign-in (configured in Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
